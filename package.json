{
  "name": "skills-sync",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI tool for syncing local skills folders across multiple AI apps",
  "bin": {
    "skills-sync": "bin/skills-sync.js"
  },
  "main": "./bin/skills-sync.js",
  "files": [
    "bin",
    "src",
    "dist",
    "README.md",
    "README.zh.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shanliuling/skills-sync.git"
  },
  "homepage": "https://github.com/shanliuling/skills-sync",
  "bugs": {
    "url": "https://github.com/shanliuling/skills-sync/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "skills",
    "ai",
    "sync",
    "claude",
    "gemini",
    "cli"
  ],
  "author": "shanliuling",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node bin/skills-sync.js",
    "dev": "node --watch bin/skills-sync.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build && node bin/skills-sync.js --version && npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "inquirer": "^9.2.15",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.6.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^1.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  }
}
