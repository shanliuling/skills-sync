{
  "name": "skills-sync",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI tool for syncing local skills folders across multiple AI apps",
  "bin": {
    "skills-sync": "./bin/skills-sync.js"
  },
  "main": "./bin/skills-sync.js",
  "files": [
    "bin",
    "src",
    "README.md",
    "README.zh.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shanliuling/skills-sync.git"
  },
  "homepage": "https://github.com/shanliuling/skills-sync",
  "bugs": {
    "url": "https://github.com/shanliuling/skills-sync/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "skills",
    "ai",
    "sync",
    "claude",
    "gemini",
    "cli"
  ],
  "author": "shanliuling",
  "license": "MIT",
  "scripts": {
    "start": "node bin/skills-sync.js",
    "dev": "node --watch bin/skills-sync.js",
    "prepublishOnly": "node bin/skills-sync.js --version && npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "inquirer": "^9.2.15",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.6.1"
  }
}
